PORT=3010
# Database:
# - sqlite: default lokal, tidak perlu server database
# - mysql: MySQL/MariaDB
# - sqlserver: Microsoft SQL Server
# DB_CONNECTION=sqlite
# DATABASE_PATH=./database/app.db

# Postgres (Supabase)
# DB_CONNECTION=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# (Supabase biasanya butuh SSL; DATABASE_URL dari dashboard sudah include param sslmode=require)


DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mapping
DB_USER=root
DB_PASSWORD=

# DB_CONNECTION=sqlserver
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_DATABASE=mapping
# DB_USER=sa
# DB_PASSWORD=your_password
# DB_ENCRYPT=0
# DB_TRUST_SERVER_CERTIFICATE=1

ALLOW_DB_CREATE=1   
AUTO_SEED_DEMO=1


UPLOAD_DIR=./uploads
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_secret
DEFAULT_SUPERADMIN_EMAIL=jonusadeveloper@gmail.com
DEFAULT_SUPERADMIN_PASSWORD=superadmin123

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=app_password
# SMTP_SECURE=0
# EMAIL_FROM="Mapping System <you@example.com>"

# Telegram (opsional, untuk kirim laporan via bot)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF
