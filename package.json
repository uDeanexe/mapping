{
  "name": "mapping-jaringan",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev --workspace server\" \"npm:dev --workspace client\"",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace client",
    "preview": "npm run preview --workspace client"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0"
  }
}
