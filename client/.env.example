# Supabase (dipakai langsung dari client, tanpa server)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Alternatif nama env (kalau sudah terlanjur di Vercel):
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY
# Optional: nama bucket Storage untuk upload image
VITE_SUPABASE_BUCKET=uploads

# Map View memakai OpenStreetMap (Leaflet), tidak butuh API key
